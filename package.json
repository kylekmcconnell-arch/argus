{
  "name": "argus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
    "dev:full": "concurrently -n web,api -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "build": "node scripts/build-collector.mjs && tsc -b && vite build",
    "typecheck": "tsc -b && tsc -p server/tsconfig.json --noEmit && tsc -p tsconfig.api.json --noEmit",
    "test": "vitest run",
    "calibrate": "tsx src/calibration/calibrate.ts",
    "calibrate:json": "tsx src/calibration/calibrate.ts --json",
    "canary:offline": "tsx scripts/release-canary.ts",
    "canary:offline:json": "tsx scripts/release-canary.ts --json",
    "truth:check": "tsx scripts/source-of-truth-check.ts",
    "quality": "npm run truth:check && npm run canary:offline && npm run calibrate && npm test && npm run typecheck",
    "seed:local-report": "tsx scripts/seed-local-report.ts",
    "check-env": "tsx scripts/check-env.ts",
    "test:db": "supabase test db supabase/tests/report_activation_quality_guard.sql supabase/tests/database/persist_report_version_bundle.test.sql",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "2.110.2",
    "@tailwindcss/vite": "^4.3.1",
    "@vercel/functions": "3.7.5",
    "@vercel/og": "^0.11.1",
    "framer-motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.23",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "26.1.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@vercel/node": {
      "path-to-regexp": "6.3.0",
      "undici": "6.27.0"
    },
    "@vercel/python-analysis": {
      "js-yaml": "4.3.0",
      "minimatch": "10.2.5",
      "smol-toml": "1.7.0"
    },
    "@vercel/static-config": {
      "ajv": "8.20.0"
    }
  }
}
