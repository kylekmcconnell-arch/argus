# ARGUS collector provider keys. Copy to `.env` and fill what you have.
# With NO keys set, the collector falls back to curated dossiers (the demo still
# runs). Each key set flips that provider to live; the report badge shows LIVE
# only when real collection happened. Run `npm run check-env` to see what is
# wired without printing any values. Same vars go into Vercel env for prod.
#
# SECURITY: never paste a key into chat/issues/commits. .env is gitignored.
# The only must-haves to flip people-audits live are ANTHROPIC_API_KEY + ONE X
# source (XAI_API_KEY or TWITTERAPI_KEY). The rest add depth and can wait.

# ── X (the signature path) ───────────────────────────────────────────────
# Grok / xAI: real-time X CONTENT for testimonial acknowledgment + sentiment.
# Get: https://console.x.ai
XAI_API_KEY=
# ARGUS_GROK_MODEL=grok-4-fast
# twitterapi.io: the follow graph (official X API gates this behind ~$42k/mo).
# Get: https://twitterapi.io
TWITTERAPI_KEY=

# ── People / company / funding ───────────────────────────────────────────
# People Data Labs: defensible LinkedIn-derived identity + career history.
# Get: https://dashboard.peopledatalabs.com
PDL_API_KEY=
# Crunchbase: funding rounds, investors, acquirers (F2/F3/I2). Paid.
CRUNCHBASE_API_KEY=

# ── Crypto market + on-chain ─────────────────────────────────────────────
# CoinGecko: optional; public endpoint works keyless (rate limited).
# Free Demo key: https://www.coingecko.com/en/developers/dashboard
COINGECKO_API_KEY=
# DexScreener needs no key (free, keyless).
# Helius (Solana wallet forensics) — generous free tier. Get: https://helius.dev
HELIUS_API_KEY=
# Bitquery (multi-chain deployer/holder forensics). Get: https://bitquery.io
BITQUERY_API_KEY=

# ── Reputation ───────────────────────────────────────────────────────────
# Reddit: community FUD scan (free, OAuth client credentials).
# Create a "script" app at https://www.reddit.com/prefs/apps — the id is under
# the app name, plus its secret. Non-Devvit API use also needs the access form.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── The analyst ──────────────────────────────────────────────────────────
# Claude scores axes + writes rationales/headline from collected evidence.
# Get: https://console.anthropic.com (Settings -> API Keys; needs API credits,
# separate from a Claude.ai subscription).
ANTHROPIC_API_KEY=
# ARGUS_ANALYST_MODEL=claude-sonnet-4-6

# Server port (client proxies /api -> here).
# ARGUS_PORT=8787

# ── Identity, workspaces, cases, and the shared trust graph ───────────────
# Run the committed Supabase migrations before deploying. The publishable key
# is safe in the browser; the service-role key is SECRET and server-only.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Preferred 2026 server credential (opaque sb_secret_* value). Server-only.
SUPABASE_SECRET_KEY=
# Legacy JWT service-role fallback during migration; remove once rotated.
SUPABASE_SERVICE_ROLE_KEY=

# Vite embeds these two public values at build time. Use the same project URL
# and publishable key as above; never use a secret/service key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# The first approved owner is provisioned after Supabase verifies their email.
# That owner can invite and manage everyone else under Audit log → Workspace
# access. The analyst/viewer lists remain useful as emergency bootstrap fallbacks.
# Values are comma-separated, case-insensitive emails.
ARGUS_OWNER_EMAILS=
ARGUS_ANALYST_EMAILS=
ARGUS_VIEWER_EMAILS=
# Exact public origin used in owner-sent invitation links.
ARGUS_APP_ORIGIN=

# The project currently has no Auth users. Set this to true only while the
# approved emails create their first magic-link accounts, then return it to
# false. Non-allowlisted users may authenticate but cannot enter a workspace.
VITE_ARGUS_ALLOW_BOOTSTRAP_SIGNUP=false

# Paid investigation guardrails. Defaults are 25/day for analysts and 100/day
# for owners when these are omitted.
ARGUS_DAILY_INVESTIGATION_LIMIT=25
ARGUS_OWNER_DAILY_INVESTIGATION_LIMIT=100
# Weighted budget shared by every API route (expensive LLM/provider routes cost
# more units). Defaults: analysts 300/day, owners 1500/day.
ARGUS_DAILY_API_UNITS=300
ARGUS_OWNER_DAILY_API_UNITS=1500
ARGUS_METHODOLOGY_VERSION=2026-07-p0
# Browser origins allowed to call /api/v1 with an Authorization header.
# Server-to-server calls are unaffected by CORS.
ARGUS_CORS_ORIGINS=

# ── Future infra (not yet wired; here so the list is complete) ───────────
# Telegram bot (distribution): token from @BotFather.
# TELEGRAM_BOT_TOKEN=
